{
  "id": "weather-forecast",
  "name": "Weather Forecast",
  "description": "Real-time weather data using Open-Meteo API. Cross-platform WASM extension with dashboard widget. Displays temperature, humidity, wind speed, and more with a beautiful weather card component.",
  "version": "0.1.0",
  "author": "NeoMind Team",
  "license": "MIT",
  "categories": [
    "weather",
    "data",
    "wasm",
    "cross-platform",
    "dashboard"
  ],
  "homepage": "https://github.com/camthink-ai/NeoMind-Extensions/tree/main/extensions/weather-forecast",
  "repository": "https://github.com/camthink-ai/NeoMind-Extensions",
  "capabilities": {
    "tools": [
      {
        "name": "get_weather",
        "display_name": "Get Weather",
        "description": "Get current weather for a city",
        "parameters": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string",
              "description": "City name to get weather for"
            }
          },
          "required": ["city"]
        },
        "returns": "object"
      }
    ],
    "metrics": [
      {
        "name": "temperature_c",
        "display_name": "Temperature",
        "data_type": "Float",
        "unit": "°C",
        "description": "Current temperature in Celsius",
        "min": -100.0,
        "max": 100.0
      },
      {
        "name": "feels_like_c",
        "display_name": "Feels Like",
        "data_type": "Float",
        "unit": "°C",
        "description": "Feels like temperature in Celsius",
        "min": -100.0,
        "max": 100.0
      },
      {
        "name": "humidity_percent",
        "display_name": "Humidity",
        "data_type": "Integer",
        "unit": "%",
        "description": "Relative humidity percentage",
        "min": 0.0,
        "max": 100.0
      },
      {
        "name": "wind_speed_kmph",
        "display_name": "Wind Speed",
        "data_type": "Float",
        "unit": "km/h",
        "description": "Wind speed in kilometers per hour",
        "min": 0.0,
        "max": null
      },
      {
        "name": "wind_direction_deg",
        "display_name": "Wind Direction",
        "data_type": "Integer",
        "unit": "°",
        "description": "Wind direction in degrees",
        "min": 0.0,
        "max": 360.0
      },
      {
        "name": "cloud_cover_percent",
        "display_name": "Cloud Cover",
        "data_type": "Integer",
        "unit": "%",
        "description": "Cloud cover percentage",
        "min": 0.0,
        "max": 100.0
      },
      {
        "name": "pressure_hpa",
        "display_name": "Pressure",
        "data_type": "Float",
        "unit": "hPa",
        "description": "Atmospheric pressure in hectopascals",
        "min": 900.0,
        "max": 1100.0
      }
    ],
    "commands": [
      {
        "name": "get_weather",
        "display_name": "Get Weather",
        "description": "Get current weather for a city",
        "parameters": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string",
              "description": "City name to get weather for"
            }
          },
          "required": ["city"]
        }
      }
    ]
  },
  "dashboard_components": [
    {
      "type": "weather-card",
      "name": "Weather Card",
      "description": "Display current weather with gradient background that changes based on conditions. Supports city search and auto-refresh.",
      "category": "custom",
      "icon": "Cloud",
      "bundle_path": "frontend/dist/weather-card.js",
      "export_name": "WeatherCard"
    }
  ],
  "builds": {
    "wasm": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/weather-forecast-0.1.0/weather-forecast-0.1.0.nep",
      "sha256": "",
      "size": 0
    }
  },
  "requirements": {
    "min_neomind_version": "0.5.0",
    "network": true,
    "api_keys": []
  },
  "permissions": [
    "http://geocoding-api.open-meteo.com",
    "https://geocoding-api.open-meteo.com",
    "http://api.open-meteo.com",
    "https://api.open-meteo.com"
  ],
  "safety": {
    "timeout_seconds": 30,
    "max_memory_mb": 50
  },
  "config_parameters": [
    {
      "name": "city",
      "title": "Default City",
      "description": "Default city for weather data collection",
      "type": "string",
      "default": "Beijing"
    },
    {
      "name": "collect_interval",
      "title": "Collection Interval",
      "description": "Data collection interval in seconds (0 to disable auto-collection)",
      "type": "integer",
      "default": 300,
      "minimum": 0,
      "maximum": 86400
    }
  ]
}