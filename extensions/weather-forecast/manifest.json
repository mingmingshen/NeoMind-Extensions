{
  "format": "neomind-extension-package",
  "format_version": "1.0",
  "id": "weather-forecast",
  "name": "Weather Forecast",
  "version": "0.1.0",
  "description": "Real-time weather data using Open-Meteo API",
  "author": "NeoMind Team",
  "license": "MIT",
  "homepage": "https://github.com/camthink-ai/NeoMind-Extensions",
  "type": "wasm",
  "neomind": {
    "min_version": "0.5.0"
  },
  "binaries": {
    "wasm": "binaries/wasm/extension.wasm"
  },
  "permissions": [
    "http://geocoding-api.open-meteo.com",
    "https://geocoding-api.open-meteo.com",
    "http://api.open-meteo.com",
    "https://api.open-meteo.com"
  ],
  "config_parameters": [
    {
      "name": "city",
      "display_name": "City",
      "description": "Default city for weather data collection",
      "type": "string",
      "default": "Beijing",
      "required": false
    },
    {
      "name": "collect_interval",
      "display_name": "Collection Interval",
      "description": "Data collection interval in seconds (0 to disable auto-collection)",
      "type": "number",
      "default": 300,
      "min": 0,
      "max": 86400,
      "required": false
    }
  ],
  "metrics": [
    {
      "name": "temperature_c",
      "display_name": "Temperature",
      "data_type": "float",
      "unit": "°C",
      "min": -100,
      "max": 100
    },
    {
      "name": "feels_like_c",
      "display_name": "Feels Like",
      "data_type": "float",
      "unit": "°C",
      "min": -100,
      "max": 100
    },
    {
      "name": "humidity_percent",
      "display_name": "Humidity",
      "data_type": "integer",
      "unit": "%",
      "min": 0,
      "max": 100
    },
    {
      "name": "wind_speed_kmph",
      "display_name": "Wind Speed",
      "data_type": "float",
      "unit": "km/h",
      "min": 0
    },
    {
      "name": "wind_direction_deg",
      "display_name": "Wind Direction",
      "data_type": "integer",
      "unit": "°",
      "min": 0,
      "max": 360
    },
    {
      "name": "cloud_cover_percent",
      "display_name": "Cloud Cover",
      "data_type": "integer",
      "unit": "%",
      "min": 0,
      "max": 100
    },
    {
      "name": "pressure_hpa",
      "display_name": "Pressure",
      "data_type": "float",
      "unit": "hPa",
      "min": 900,
      "max": 1100
    }
  ],
  "commands": [
    {
      "name": "get_weather",
      "display_name": "Get Weather",
      "description": "Get current weather for a city",
      "parameters": [
        {
          "name": "city",
          "display_name": "City",
          "description": "City name to get weather for",
          "type": "string",
          "required": true
        }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "city": { "type": "string" },
          "country": { "type": "string" },
          "temperature_c": { "type": "number" },
          "feels_like_c": { "type": "number" },
          "humidity_percent": { "type": "integer" },
          "wind_speed_kmph": { "type": "number" },
          "wind_direction_deg": { "type": "integer" },
          "wind_direction": { "type": "string" },
          "cloud_cover_percent": { "type": "integer" },
          "pressure_hpa": { "type": "number" },
          "description": { "type": "string" },
          "is_day": { "type": "boolean" },
          "timestamp": { "type": "string" }
        }
      }
    }
  ],
  "dashboard_components": [
    {
      "type": "weather-card",
      "name": "Weather Card",
      "description": "Display current weather with gradient background that changes based on conditions. Supports city search and auto-refresh.",
      "category": "custom",
      "icon": "Cloud",
      "bundle_path": "frontend/dist/weather-card.js",
      "export_name": "WeatherCard",
      "size_constraints": {
        "min_w": 2,
        "min_h": 4,
        "default_w": 2,
        "default_h": 4,
        "max_w": 4,
        "max_h": 6,
        "preserve_aspect": false
      },
      "has_data_source": true,
      "has_display_config": true,
      "has_actions": false,
      "max_data_sources": 1,
      "config_schema": {
        "type": "object",
        "properties": {
          "defaultCity": {
            "type": "string",
            "description": "Default city to display weather for",
            "default": "Beijing"
          },
          "showHumidity": {
            "type": "boolean",
            "description": "Show humidity indicator",
            "default": true
          },
          "showWindSpeed": {
            "type": "boolean",
            "description": "Show wind speed indicator",
            "default": true
          },
          "refreshInterval": {
            "type": "number",
            "description": "Auto-refresh interval in milliseconds (0 to disable)",
            "default": 300000,
            "minimum": 0,
            "maximum": 3600000
          },
          "unit": {
            "type": "string",
            "description": "Temperature unit",
            "default": "celsius",
            "enum": ["celsius", "fahrenheit"]
          }
        }
      },
      "default_config": {
        "defaultCity": "Beijing",
        "showHumidity": true,
        "showWindSpeed": true,
        "refreshInterval": 300000,
        "unit": "celsius"
      },
      "variants": ["default", "compact"],
      "data_binding": {
        "extension_metric": null,
        "extension_command": "get_weather",
        "required_fields": []
      }
    }
  ],
  "build": {
    "wasm_target": "wasm32-unknown-unknown",
    "optimize": true
  }
}
