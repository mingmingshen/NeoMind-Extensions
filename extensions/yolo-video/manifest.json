{
  "id": "yolo-video",
  "name": "YOLO Video Processor",
  "description": "Real-time video stream processing with multi-protocol support (RTSP, RTMP, HLS, Camera, File)",
  "version": "0.1.0",
  "author": "NeoMind",
  "capabilities": {
    "metrics": ["active_streams", "total_frames_processed", "avg_fps", "total_detections"],
    "commands": ["start_stream", "stop_stream", "get_stream_stats"],
    "supported_protocols": ["camera", "rtsp", "rtmp", "hls", "http-ts", "file", "screen"]
  },
  "dashboard_components": [
    {
      "type": "yolo-video-display",
      "name": "YOLO Video Display",
      "description": "Real-time object detection on video streams. Supports RTSP, RTMP, HLS, Camera, File, and Screen sources.",
      "category": "custom",
      "icon": "Video",
      "bundle_path": "/frontend/dist/yolo-video-components.js",
      "export_name": "YoloVideoDisplay",
      "size_constraints": {
        "min_w": 4,
        "min_h": 4,
        "default_w": 6,
        "default_h": 5,
        "max_w": 12,
        "max_h": 8,
        "preserve_aspect": false
      },
      "has_data_source": true,
      "has_display_config": true,
      "has_actions": false,
      "max_data_sources": 1,
      "config_schema": {
        "type": "object",
        "properties": {
          "sourceUrl": {
            "type": "string",
            "description": "Video source URL. Examples: camera://0, rtsp://192.168.1.100/stream, rtmp://server/app/key, hls://example.com/stream.m3u8",
            "default": "camera://0"
          },
          "confidenceThreshold": {
            "type": "number",
            "description": "Minimum confidence for detection (0-1)",
            "default": 0.5,
            "minimum": 0,
            "maximum": 1
          },
          "maxObjects": {
            "type": "number",
            "description": "Maximum number of objects to detect per frame",
            "default": 20,
            "minimum": 1,
            "maximum": 100
          },
          "fps": {
            "type": "number",
            "description": "Target frames per second for processing",
            "default": 15,
            "minimum": 1,
            "maximum": 30
          },
          "drawBoxes": {
            "type": "boolean",
            "description": "Draw detection boxes on output",
            "default": true
          },
          "showStats": {
            "type": "boolean",
            "description": "Show FPS and detection statistics",
            "default": true
          }
        }
      },
      "default_config": {
        "sourceUrl": "camera://0",
        "confidenceThreshold": 0.5,
        "maxObjects": 20,
        "fps": 15,
        "drawBoxes": true,
        "showStats": true
      },
      "variants": ["default", "compact"],
      "examples": [
        {
          "name": "Local Camera",
          "config": { "sourceUrl": "camera://0" }
        },
        {
          "name": "RTSP Stream",
          "config": { "sourceUrl": "rtsp://192.168.1.100:554/stream?transport=tcp" }
        },
        {
          "name": "HLS Stream",
          "config": { "sourceUrl": "hls://example.com/live/stream.m3u8" }
        },
        {
          "name": "Video File",
          "config": { "sourceUrl": "file:///path/to/video.mp4?loop=true" }
        }
      ]
    }
  ]
}

