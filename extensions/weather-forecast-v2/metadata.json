{
  "id": "weather-forecast-v2",
  "name": "Weather Forecast V2",
  "version": "2.0.0",
  "description": "Real-time weather data using Open-Meteo API. Built with NeoMind Extension SDK V2.",
  "author": "NeoMind Team",
  "license": "MIT",
  "categories": ["weather", "data", "api"],
  "type": "native",
  "abi_version": 3,
  "sdk_version": "2.0.0",
  "homepage": "https://github.com/camthink-ai/NeoMind-Extensions/tree/main/extensions/weather-forecast-v2",
  "repository": "https://github.com/camthink-ai/NeoMind-Extensions",
  "keywords": ["weather", "forecast", "temperature", "humidity"],
  "frontend": {
    "components": ["WeatherCard"],
    "entrypoint": "weather-forecast-v2-components.umd.js"
  },
  "builds": {
    "darwin-aarch64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.0.0/weather-forecast-v2-2.0.0-darwin_aarch64.nep",
      "sha256": "",
      "size": 1388586
    },
    "linux-x86_64": {
      "url": "https://github.com/camthink-ai/NeoMind-Extensions/releases/download/v2.0.0/weather-forecast-v2-2.0.0-linux_amd64.nep",
      "sha256": "",
      "size": 1788014
    }
  },
  "commands": [
    {
      "name": "get_weather",
      "display_name": "Get Weather",
      "description": "Get current weather for a city",
      "parameters": [
        {
          "name": "city",
          "type": "string",
          "required": true,
          "description": "City name to get weather for"
        }
      ]
    }
  ],
  "metrics": [
    {
      "name": "temperature_c",
      "display_name": "Temperature",
      "unit": "°C",
      "type": "float"
    },
    {
      "name": "humidity_percent",
      "display_name": "Humidity",
      "unit": "%",
      "type": "integer"
    },
    {
      "name": "wind_speed_kmph",
      "display_name": "Wind Speed",
      "unit": "km/h",
      "type": "float"
    },
    {
      "name": "request_count",
      "display_name": "Request Count",
      "type": "integer"
    }
  ]
}