{
  "id": "image-analyzer-v2",
  "version": "2.0.0",
  "entrypoint": "image-analyzer-v2-components.umd.cjs",
  "components": [
    {
      "name": "ImageAnalyzer",
      "type": "widget",
      "displayName": "Image Analyzer V2",
      "description": "AI-powered object detection using YOLOv8. Upload images to detect and identify objects. Built with NeoMind Extension SDK V2.",
      "icon": "image",
      "defaultSize": { "width": 400, "height": 350 },
      "minSize": { "width": 300, "height": 250 },
      "maxSize": { "width": 600, "height": 500 },
      "configSchema": {
        "showMetrics": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show detection metrics in header"
        },
        "maxImageSize": {
          "type": "number",
          "required": false,
          "default": 10485760,
          "description": "Maximum image file size in bytes"
        },
        "confidenceThreshold": {
          "type": "number",
          "required": false,
          "default": 0.5,
          "description": "Minimum confidence threshold for detections"
        },
        "variant": {
          "type": "string",
          "required": false,
          "default": "default",
          "description": "Display variant (default or compact)"
        }
      },
      "refreshable": false,
      "refreshInterval": 0
    }
  ],
  "i18n": {
    "defaultLanguage": "en",
    "supportedLanguages": ["en", "zh"]
  },
  "dependencies": {
    "react": ">=18.0.0"
  }
}
