{
  "id": "yolo-video-v2",
  "version": "2.0.0",
  "entrypoint": "yolo-video-v2-components.umd.cjs",
  "components": [
    {
      "name": "YoloVideoDisplay",
      "type": "panel",
      "displayName": "YOLO Video V2",
      "description": "Real-time object detection on video streams using YOLOv11. Supports Camera, RTSP, HLS, and RTMP sources. Built with NeoMind Extension SDK V2.",
      "icon": "video",
      "defaultSize": { "width": 480, "height": 360 },
      "minSize": { "width": 320, "height": 240 },
      "maxSize": { "width": 800, "height": 600 },
      "configSchema": {
        "sourceUrl": {
          "type": "string",
          "required": false,
          "default": "camera://0",
          "description": "Video source URL (camera://0, rtsp://..., hls://..., rtmp://...)"
        },
        "confidenceThreshold": {
          "type": "number",
          "required": false,
          "default": 0.5,
          "description": "Minimum confidence threshold for detections"
        },
        "maxObjects": {
          "type": "number",
          "required": false,
          "default": 20,
          "description": "Maximum number of objects to detect per frame"
        },
        "fps": {
          "type": "number",
          "required": false,
          "default": 15,
          "description": "Target frames per second"
        },
        "drawBoxes": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Draw bounding boxes on detected objects"
        },
        "showStats": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Show detection statistics"
        },
        "variant": {
          "type": "string",
          "required": false,
          "default": "default",
          "description": "Display variant (default or compact)"
        }
      },
      "refreshable": false,
      "refreshInterval": 0
    }
  ],
  "i18n": {
    "defaultLanguage": "en",
    "supportedLanguages": ["en", "zh"]
  },
  "dependencies": {
    "react": ">=18.0.0"
  }
}
